PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/tsm_erp
# For Atlas, use mongodb+srv://... from the Atlas dashboard.
# If you see "querySrv ECONNREFUSED" on Windows, the app auto-uses Google/Cloudflare DNS.
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:3000
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880
